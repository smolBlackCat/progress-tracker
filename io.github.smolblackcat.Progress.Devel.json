{
  "id": "io.github.smolblackcat.Progress.Devel",
  "runtime": "org.gnome.Platform",
  "runtime-version": "50",
  "sdk": "org.gnome.Sdk",
  "command": "progress-debug",
  "finish-args": [
    "--socket=fallback-x11",
    "--socket=wayland",
    "--device=dri",
    "--share=ipc"
  ],
  "cleanup": [
    "/include",
    "/lib/cmake",
    "/lib/giomm-2.68",
    "/lib/pkgconfig",
    "/share/doc",
    "/share/pkgconfig",
    "*.la",
    "*.a"
  ],
  "modules": [
    {
      "name": "gtkmm",
      "buildsystem": "meson",
      "config-opts": [
        "-Dmaintainer-mode=false",
        "-Dbuild-documentation=false",
        "-Dbuild-demos=false",
        "-Dbuild-tests=false"
      ],
      "cleanup": [
        "/lib/gdkmm-*",
        "/lib/gtkmm-*"
      ],
      "sources": [
        {
          "type": "archive",
          "url": "https://download.gnome.org/sources/gtkmm/4.20/gtkmm-4.20.0.tar.xz",
          "sha256": "daad9bf9b70f90975f91781fc7a656c923a91374261f576c883cd3aebd59c833"
        }
      ],
      "modules": [
        {
          "name": "libsigc++",
          "buildsystem": "meson",
          "config-opts": [
            "-Dmaintainer-mode=false",
            "-Dbuild-documentation=false",
            "-Dbuild-manual=false",
            "-Dvalidation=false",
            "-Dbuild-examples=false",
            "-Dbuild-tests=false"
          ],
          "cleanup": [
            "/lib/sigc++-3.0"
          ],
          "sources": [
            {
              "type": "archive",
              "url": "https://github.com/libsigcplusplus/libsigcplusplus/releases/download/3.8.0/libsigc++-3.8.0.tar.xz",
              "sha256": "502a743bb07ed7627dd41bd85ec4b93b4954f06b531adc45818d24a959f54e36"
            }
          ]
        },
        {
          "name": "cairomm",
          "buildsystem": "meson",
          "config-opts": [
            "-Dmaintainer-mode=false",
            "-Dbuild-documentation=false",
            "-Dbuild-examples=false",
            "-Dbuild-tests=false"
          ],
          "cleanup": [
              "/lib/cairomm-*"
          ],
          "sources": [
            {
              "type": "archive",
              "url": "https://www.cairographics.org/releases/cairomm-1.19.0.tar.xz",
              "sha256": "8b14f03a0e5178c7ff8f7b288cb342a61711c84c9fbed6e663442cfcc873ce5b"
            }
          ]
        },
        {
          "name": "glibmm",
          "buildsystem": "meson",
          "config-opts": [
            "-Dmaintainer-mode=false",
            "-Dbuild-documentation=false",
            "-Dbuild-examples=false"
          ],
          "cleanup": [
            "/lib/glibmm-*",
            "/lib/libglibmm_generate_extra_defs*"
          ],
          "sources": [
            {
              "type": "archive",
              "url": "https://download.gnome.org/sources/glibmm/2.86/glibmm-2.86.0.tar.xz",
              "sha256": "39c0e9f6da046d679390774efdb9ad564436236736dc2f7825e614b2d4087826"
            }
          ]
        },
        {
          "name": "pangomm",
          "buildsystem": "meson",
          "config-opts": [
            "-Dmaintainer-mode=false",
            "-Dbuild-documentation=false"
          ],
          "cleanup": [
            "/lib/pangomm-*"
          ],
          "sources": [
            {
              "type": "archive",
              "url": "https://download.gnome.org/sources/pangomm/2.56/pangomm-2.56.1.tar.xz",
              "sha256": "539f5aa60e9bdc6b955bb448e2a62cc14562744df690258040fbb74bf885755d"
            }
          ]
        }
      ]
    },
    {
      "name": "tinyxml2",
      "buildsystem": "meson",
      "sources": [
        {
          "type": "git",
          "url": "https://github.com/leethomason/tinyxml2.git",
          "tag": "11.0.0",
          "commit": "9148bdf719e997d1f474be6bcc7943881046dba1"
        }
      ]
    },
    {
      "name": "spdlog",
      "buildsystem": "cmake-ninja",
      "config-opts": [
        "-DSPDLOG_BUILD_EXAMPLE=OFF",
        "-DSPDLOG_BUILD_TESTS=OFF",
        "-DSPDLOG_ENABLE_PCH=ON",
        "-DSPDLOG_BUILD_SHARED=ON"
      ],
      "sources": [
        {
          "type": "git",
          "url": "https://github.com/gabime/spdlog.git",
          "tag": "v1.17.0",
          "commit": "79524ddd08a4ec981b7fea76afd08ee05f83755d"
        }
      ]
    },
    {
      "name": "catch2",
      "buildsystem": "cmake-ninja",
      "builddir": true,
      "config-opts": [
        "-Dtests=false"
      ],
      "sources": [
        {
          "type": "git",
          "url": "https://github.com/catchorg/Catch2.git",
          "tag": "v3.13.0",
          "commit": "29c9844f688acb27c87338c39cd186ebfe41aa19"
        }
      ]
    },
    {
      "name": "progress-tracker",
      "buildsystem": "cmake-ninja",
      "builddir": true,
      "config-opts": [
        "-DDEVELOPMENT=ON",
        "-DFLATPAK=ON",
        "-DCMAKE_INSTALL_PREFIX=/app"
      ],
      "post-install": ["glib-compile-schemas /app/share/glib-2.0/schemas/"],
      "sources": [
        {
          "type": "dir",
          "path": "./"
        }
      ]
    }
  ]
}
